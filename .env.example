# Copy to `.env` and fill in your real values. `.env` is gitignored.
#
# Required for LLM insight generation (backend/insights.py).
# Without this key, build_data.py still runs — it just skips the LLM step
# and leaves INSIGHTS.Q1..Q14 as null (JSX falls back to terse templates).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional — override the insight cache location. Defaults to
# .insight_cache.json in the project root.
#INSIGHT_CACHE_PATH=.insight_cache.json
